@model IEnumerable<ST10076452_POE_PART1_EventEase.Models.BookingDetailsViewModel>

<form method="get">
    <input type="text" name="searchTerm" placeholder="Search by Booking ID or Event Name" />
    <button type="submit">Search</button>
</form>

<table class="table">
    <thead>
        <tr>
            <th>Booking ID</th>
            <th>Event</th>
            <th>Event Description</th>
            <th>Venue</th>
            <th>Location</th>
            <th>Capacity</th>
            <th>Date</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var booking in Model)
        {
            <tr>
                <td>@booking.BookingID</td>
                <td>@booking.EventName</td>
                <td>@booking.Description</td>
                <td>@booking.VenueName</td>
                <td>@booking.Location</td>
                <td>@booking.Capacity</td>
                <td>@booking.BookingDate.ToShortDateString()</td>
            </tr>
        }
    </tbody>
</table>
